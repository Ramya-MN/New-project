from sentence_transformers import SentenceTransformer, util
import numpy as np
import pandas as pd

# Load your FinMPNet model
model = SentenceTransformer(r"../shared/cplegsc/Feb_2026_KT/models/fin-mpnet-base")

THRESHOLD = 0.6  # tune if needed

def check_similarity(chat, keyword):
    # Split chat into lines
    lines = [line.strip() for line in str(chat).split('\n') if line.strip()]
    
    if len(lines) == 0:
        return 0.0, False
    
    # Encode
    keyword_emb = model.encode(keyword, normalize_embeddings=True)
    line_embs = model.encode(lines, normalize_embeddings=True)
    
    # Cosine similarity (dot product since normalized)
    scores = np.dot(line_embs, keyword_emb)
    
    max_score = float(np.max(scores))
    
    return max_score, max_score >= THRESHOLD


